# ── Database ──
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/ledger?sslmode=require

# ── Redis ──
REDIS_URL=rediss://default:xxx@us1-xxx.upstash.io:6379

# ── JWT Signing (ES256) ──
# Generate with: openssl ecparam -genkey -name prime256v1 -noout | openssl pkcs8 -topk8 -nocrypt
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Token Encryption (AES-256-GCM) ──
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# ── AI API Keys ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Google OAuth (Server-side) ──
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Microsoft OAuth (Server-side) ──
MSAL_CLIENT_ID=xxx
MSAL_CLIENT_SECRET=xxx
MSAL_TENANT_ID=common

# ── Apple Push Notifications ──
APNS_KEY_ID=ABC123
APNS_TEAM_ID=DEF456
APNS_BUNDLE_ID=com.yourcompany.ledger
# Base64-encoded .p8 file content
APNS_KEY_BASE64=LS0tLS1CRUdJTi...

# ── Apple App Store Server API ──
APPSTORE_ISSUER_ID=xxx
APPSTORE_KEY_ID=xxx
APPSTORE_BUNDLE_ID=com.yourcompany.ledger
# Base64-encoded .p8 key
APPSTORE_KEY_BASE64=LS0tLS1CRUdJTi...

# ── Server ──
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
