{
  "name": "ledger-backend",
  "version": "1.0.0",
  "description": "Backend API and worker for Inbox Ledger",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "tsx src/worker/index.ts",
    "worker:start": "node dist/worker/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^2.0.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "bullmq": "^5.4.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.0",
    "jose": "^5.2.0",
    "nanoid": "^5.0.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "postgres": "^3.4.8",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.21.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
